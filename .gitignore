# Секреты и окружение
.env

# База данных и данные (не хранятся в репозитории)
*.db
*.sqlite
*.sqlite3
data/*
!data/.gitkeep

# Загруженные файлы, отчёты, бэкапы, логи
uploads/*
!uploads/.gitkeep
reports/*
!reports/.gitkeep
backups/*
!backups/.gitkeep
logs/*
!logs/.gitkeep

# Пользовательские Excel/CSV
*.xlsx
*.xls
*.csv

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Редакторы
.vscode/
.idea/
